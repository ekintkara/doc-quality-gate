# DQG Configuration
# Copy this file to .env and fill in the values

# Z.AI API Key (required)
# Get your key from: https://z.ai
ZAI_API_KEY=your_zai_api_key_here

# LiteLLM Master Key (required for proxy)
# Auto-generated if not set
LITELLM_MASTER_KEY=

# Jira Integration (optional - for from-jira command)
# DQG_JIRA_BASE_URL=https://your-domain.atlassian.net
# DQG_JIRA_EMAIL=your@email.com
# DQG_JIRA_API_TOKEN=your-api-token
# DQG_JIRA_PROJECT=PROJ
# DQG_JIRA_DEFAULT_CONTEXT_PATH=
